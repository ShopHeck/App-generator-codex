{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-generator-codex/schemas/app-spec.schema.json",
  "title": "AppSpec",
  "type": "object",
  "required": [
    "specVersion",
    "metadata",
    "capabilities",
    "platformTargets",
    "product",
    "designSystem",
    "navigation",
    "dataModels",
    "screens",
    "integrations",
    "export"
  ],
  "properties": {
    "specVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "metadata": {
      "type": "object",
      "required": ["appName", "platform", "targetDevice", "createdAt"],
      "properties": {
        "appName": { "type": "string", "minLength": 1 },
        "platform": { "type": "string", "minLength": 1 },
        "targetDevice": { "type": "string", "minLength": 1 },
        "createdAt": { "type": "string", "minLength": 1 }
      }
    },
    "capabilities": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "platformTargets": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "product": { "type": "object" },
    "designSystem": { "type": "object" },
    "navigation": {
      "type": "object",
      "required": ["tabs"],
      "properties": {
        "tabs": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "object" }
        }
      }
    },
    "dataModels": { "type": "array" },
    "screens": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "object" }
    },
    "integrations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string" }
        }
      }
    },
    "export": { "type": "object" }
  }
}
