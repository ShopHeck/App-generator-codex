# .env.example — environment variable reference for App Generator Codex
#
# Copy this file to .env.local for local development (never commit secrets).
# In production (Fly.io), set secrets with:  flyctl secrets set KEY=value
#
# Variables marked [required] must be set for the API to function correctly.
# Variables marked [optional] enable extra features but have safe defaults.

# ── Database ─────────────────────────────────────────────────────────────────
# [required] PostgreSQL connection.
# Prefer the full URL in production; individual vars are supported for dev.

POSTGRES_URL=
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=app_generator
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=
# POSTGRES_SSL=require          # set to "require" for managed Postgres (e.g. Fly, Supabase)
# POSTGRES_POOL_MAX=10

# ── Authentication ────────────────────────────────────────────────────────────
# [required] Choose exactly one auth mode.
#
# HMAC mode — simpler, recommended for self-hosted / internal APIs:
JWT_SECRET=change-me-to-a-random-string-at-least-32-characters-long
#
# Supabase JWKS mode — use this when Supabase issues your JWTs:
# SUPABASE_URL=https://<project>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>  # server-side only, never expose to clients

# ── OpenAI ────────────────────────────────────────────────────────────────────
# [optional] Enables LLM-powered intent extraction.
# When absent, the API falls back to rule-based heuristics automatically.

OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini

# ── Storage ───────────────────────────────────────────────────────────────────
# [optional] Supabase Storage bucket for export artifact uploads.
# Requires SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY to be set.

# STORAGE_BUCKET=exports

# ── Server ────────────────────────────────────────────────────────────────────
# [optional] Runtime configuration with sane defaults.

NODE_ENV=production
PORT=3001
LOG_LEVEL=info
